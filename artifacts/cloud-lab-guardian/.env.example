# Cloud Lab Guardian — Environment Variables
# Copy this file to .env.local and fill in the values you need.
# Never commit .env.local or any file containing real secrets to Git.

# ------------------------------------------------------------
# Optional: Lambda Function URL backend
# If set, the app will call this URL first and fall back to the
# local deterministic pipeline if the call fails.
# Leave blank to always run the local pipeline (default).
# ------------------------------------------------------------
LAB_GUARDIAN_API_URL=

# ------------------------------------------------------------
# Required: server port (set automatically in Replit/CI)
# Only needed if you run the dev server or build outside Replit.
# ------------------------------------------------------------
PORT=3000
